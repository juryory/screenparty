{
  "name": "screenparty",
  "main": "src/index.js",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "party.juryory.com", "custom_domain": true }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "ROOM", "class_name": "Room" },
      // 单例账号/会话存储(idFromName("global")):用户表 + 会话表
      { "name": "AUTH", "class_name": "Auth" },
      // 单例服务器结构(idFromName("global")):分类 / 频道 / 成员角色
      { "name": "GUILD", "class_name": "Guild" }
    ]
  },
  "migrations": [
    // SQLite-backed DO:Workers 免费计划即可使用
    { "tag": "v1", "new_sqlite_classes": ["Room"] },
    { "tag": "v2", "new_sqlite_classes": ["Auth"] },
    { "tag": "v3", "new_sqlite_classes": ["Guild"] }
  ]
  // 鉴权:首次访问时用下列 secret 自动创建管理员账号(不进代码库)
  //   wrangler secret put ADMIN_USERNAME
  //   wrangler secret put ADMIN_PASSWORD
  //   wrangler secret put ADMIN_NICKNAME   // 可选,缺省用用户名
  //   wrangler secret put GUILD_NAME       // 可选,服务器显示名(ADMIN_USERNAME 即所有者)
  // 本地开发把它们写进 .dev.vars(已被 .gitignore 忽略)
  //
  // 可选:接入 Cloudflare Realtime TURN 作打洞失败兜底
  // 在 dashboard 创建 TURN key 后执行:
  //   wrangler secret put TURN_KEY_ID
  //   wrangler secret put TURN_KEY_API_TOKEN
}
